APP_NAME=HERDAYs AI Service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8090

# Shared secret used by the Express backend when calling internal endpoints.
SERVICE_TOKEN=change-me

# OpenAI provider. Leave OPENAI_API_KEY empty to use deterministic fallback responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30

# MongoDB Atlas Vector Search. Leave empty while developing without RAG storage.
MONGODB_URI=
MONGODB_DB_NAME=HerDay
MONGODB_VECTOR_COLLECTION=knowledge_chunks
MONGODB_VECTOR_INDEX=knowledge_vector_index
RAG_TOP_K=5

MAX_USER_MESSAGE_CHARS=2000

